{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Réservations confirmées (total)",
      "description": "Nombre total de réservations confirmées via Sokar Connect.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(sokar_connect_reservations_confirmed_total)",
          "legendFormat": "confirmed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green" }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Events analytics (total)",
      "description": "Nombre total d'événements analytics Connect (page_view, cta_clicked, etc.).",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(sokar_connect_events_total)",
          "legendFormat": "events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue" }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latence p95 par route (ms)",
      "description": "Latence p95 des routes Connect publiques. Alerte si > 500ms.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(sokar_connect_request_duration_ms_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Events par type (rate/s)",
      "description": "Taux d'événements analytics par type (page_view, cta_clicked, reservation_confirmed, etc.).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sokar_connect_events_total[5m])) by (event)",
          "legendFormat": "{{event}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Réservations confirmées (rate/min)",
      "description": "Taux de réservations confirmées par minute.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sokar_connect_reservations_confirmed_total[1m])) * 60",
          "legendFormat": "confirmed/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Appels MCP par tool (rate/s)",
      "description": "Taux d'appels aux tools MCP par tool et statut. Permet de savoir quels tools sont réellement utilisés par les clients MCP (Claude Desktop, Cursor, etc.).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sokar_mcp_tool_calls_total[5m])) by (tool, status)",
          "legendFormat": "{{tool}} / {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Hits bots IA par user-agent (rate/s)",
      "description": "Taux de crawl par bot IA sur les pages publiques Connect (restaurant, llms.txt, sitemap, robots, well-known). Permet de mesurer quels bots crawlent réellement Sokar.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sokar_connect_ia_bot_hits_total[5m])) by (bot)",
          "legendFormat": "{{bot}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Hits bots IA par path_class (total)",
      "description": "Répartition des hits bots IA par catégorie de path (restaurant, llms.txt, sitemap, robots, well-known).",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(sokar_connect_ia_bot_hits_total) by (path_class)",
          "legendFormat": "{{path_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue" }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["sokar", "connect"],
  "templating": { "list": [] },
