# .dockerignore — build context exclusions for Sokar app images.
# NOTE: currently INERT. Repo deploys via PM2 (scripts/deploy-vps.sh);
# Docker only runs infra (postgres/redis/localstack) via prebuilt images
# in infra/docker-compose.yml, which never reads this file.
# Live only when an apps/*/Dockerfile builds from repo root.

# ── Dependencies (regenerated inside the image) ──
node_modules
**/node_modules
.pnpm-store

# ── Build outputs ──
dist
**/dist
.next
**/.next
.turbo
**/.turbo
*.tsbuildinfo
**/*.tsbuildinfo

# ── VCS ──
.git

# ── Tests / coverage (not needed to build & run) ──
coverage
**/coverage
*.lcov
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# ── Docs & project meta ──
docs
**/*.md

# ── Deploy/ops scripts not needed in the image ──
scripts

# ── Editor / OS noise ──
.DS_Store
.idea
.vscode
*.swp
*.swo
*.cpuprofile

# ── Logs / caches / local data ──
*.log
**/*.log
.cache
**/.cache
tmp
**/tmp
*.sqlite
*.db

# ── Local env / secrets ──
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# ── Private keys (defense in depth) ──
*.pem
*.key
**/*.pem
**/*.key

# ── CI / Docker artefacts ──
.github
**/Dockerfile*
**/docker-compose*.yml
