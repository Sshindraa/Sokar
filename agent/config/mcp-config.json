{
  "mcpServers": {
    "hermes": {
      "command": "python3",
      "args": ["/Users/hamza/Desktop/Callyx/agent/scripts/mcp_serve.py"],
      "description": "Hermes orchestrateur — agents Callyx (planification Cascade, execution Hermes)"
    },
    "callyx-postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "${env:DATABASE_URL}"
      }
    },
    "callyx-github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "obsidian-vault": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/hamza/Desktop/Callyx/docs/obsidian"],
      "description": "Callyx Obsidian vault — lecture et écriture des notes"
    }
  }
}
