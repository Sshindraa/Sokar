{
  "mcpServers": {
    "hermes": {
      "command": "/usr/bin/python3",
      "args": ["-u", "/Users/hamza/Desktop/Sokar/tools/hermes/scripts/mcp_serve.py"],
      "description": "Hermes orchestrateur — agents Sokar via MCP"
    },
    "sokar-postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "${env:DATABASE_URL}"
      }
    },
    "sokar-github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "obsidian-vault": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/hamza/Desktop/Sokar/docs/obsidian"
      ],
      "description": "Sokar Obsidian vault — lecture et écriture des notes"
    }
  }
}
