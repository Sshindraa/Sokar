{
  "name": "sokar",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint && pnpm lint:css",
    "lint:css": "stylelint --config packages/config/.stylelintrc.json \"apps/*/src/**/*.css\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @sokar/dashboard test:e2e",
    "test:visual": "pnpm --filter @sokar/dashboard test:visual",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky",
    "db:generate": "cd packages/database && prisma generate --no-hints",
    "db:push": "cd packages/database && prisma db push",
    "db:studio": "cd packages/database && prisma studio",
    "db:seed": "pnpm --filter @sokar/database seed",
    "infra:up": "docker compose --env-file .env.local -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "test:diagnostic": "node scripts/smoke/test-stt-tts.mjs",
    "tunnel:status": "cloudflared tunnel info sokar",
    "tunnel:logs": "tail -n 50 -f ~/Library/Logs/com.cloudflare.cloudflared.err.log",
    "redis:start": "brew services start redis",
    "redis:stop": "brew services stop redis",
    "redis:status": "brew services list | grep redis",
    "node:check": "node -e \"const v=process.versions.node.split('.').map(Number); if (v[0]<20 || v[0]>=23) { console.error('Node '+process.versions.node+' not supported. Use Node >=20 <23.'); process.exit(1); } console.log('Node '+process.versions.node+' OK');\"",
    "verify:precommit": "scripts/precommit-review.sh",
    "verify:prepush": "scripts/prepush-quality-gate.sh",
    "verify:ai": "scripts/agent/hermes-diff-review.sh head",
    "pr:submit": "scripts/agent/submit-pr.sh",
    "dogfood:sokar": "scripts/smoke/dogfood-sokar.sh",
    "deploy:prod": "ssh deploy@pmbtc 'cd /opt/sokar && git pull origin main && bash scripts/deploy-vps.sh --confirm-production'",
    "deploy:staging": "ssh deploy@pmbtc 'cd /opt/sokar-staging && git pull origin main && bash scripts/deploy-staging.sh'"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "prettier": "^3.5.0",
    "prisma": "^6.0.0",
    "stylelint": "^16.26.1",
    "turbo": "^2.10.2",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "js-cookie": ">=3.0.7",
      "glob": ">=10.5.0",
      "uuid": ">=11.1.1",
      "qs": ">=6.15.2",
      "postcss": ">=8.5.10",
      "js-yaml": ">=4.2.0",
      "esbuild": ">=0.28.1",
      "@opentelemetry/core": ">=2.8.0"
    }
  },
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "packageManager": "pnpm@10.33.3"
}
