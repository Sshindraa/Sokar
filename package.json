{
  "name": "sokar",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/database/prisma/schema.prisma",
    "db:seed": "pnpm --filter @sokar/api seed",
    "test": "pnpm --filter @sokar/api test",
    "test:diagnostic": "node scripts/test-stt-tts.mjs"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5",
    "netlify-cli": "^26.1.0",
    "prettier": "^3.5.0",
    "prisma": "^6.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  }
}
