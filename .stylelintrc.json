{
  "rules": {
    "selector-max-type": [
      0,
      {
        "ignoreTypes": [
          "html",
          "body",
          "a",
          "abbr",
          "address",
          "area",
          "b",
          "bdi",
          "bdo",
          "blockquote",
          "br",
          "canvas",
          "caption",
          "cite",
          "code",
          "col",
          "colgroup",
          "data",
          "datalist",
          "dd",
          "del",
          "details",
          "dfn",
          "dl",
          "dt",
          "em",
          "embed",
          "figcaption",
          "figure",
          "h1",
          "h2",
          "h3",
          "h4",
          "h5",
          "h6",
          "hr",
          "i",
          "iframe",
          "img",
          "input",
          "ins",
          "kbd",
          "label",
          "li",
          "link",
          "map",
          "mark",
          "menu",
          "meta",
          "object",
          "ol",
          "optgroup",
          "option",
          "p",
          "param",
          "picture",
          "pre",
          "q",
          "rp",
          "rt",
          "ruby",
          "s",
          "samp",
          "script",
          "select",
          "small",
          "source",
          "span",
          "strong",
          "style",
          "svg",
          "sub",
          "summary",
          "sup",
          "table",
          "tbody",
          "td",
          "textarea",
          "tfoot",
          "th",
          "thead",
          "time",
          "title",
          "tr",
          "track",
          "u",
          "ul",
          "var",
          "video",
          "wbr"
        ]
      }
    ],
    "color-no-hex": true,
    "color-function-notation": "modern",
    "declaration-no-important": true,
    "declaration-property-value-allowed-list": {
      "z-index": [
        "0",
        "1",
        "10",
        "20",
        "30",
        "40",
        "50",
        "auto",
        "inherit",
        "initial",
        "revert",
        "unset",
        "/^var\\(.*\\)$/"
      ]
    },
    "declaration-property-unit-allowed-list": {
      "font-size": ["rem", "em", "%", "vh", "vw", "ex", "ch"]
    }
  },
  "ignoreFiles": [
    "node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/out/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.min.css"
  ]
}
