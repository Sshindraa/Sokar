{
  "css.lint.unknownAtRules": "ignore",
  "git.enabled": false,
  "scm.inputValueSource": "default",
  "extensions.supportUntrustedWorkspaces": {
    "google.geminicodeassist": false
  },
  "files.exclude": {
    "docs/obsidian/.obsidian": true
