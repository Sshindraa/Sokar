generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth tables supprimées ────────────────────────────────────────
// User, Session, Account, Verification étaient marquées @@ignore
// car Clerk gère 100% de l'authentification.
// Les tables restent en DB mais ne polluent plus le schema Prisma.
// Pour les dropper : DROP TABLE IF EXISTS users, sessions, accounts, verifications CASCADE;

model Restaurant {
  id                    String                 @id @default(uuid())
  name                  String
  plan                  Plan                   @default(STARTER)
  managerPhone          String                 @map("manager_phone")
  managerEmail          String                 @map("manager_email")
  phoneNumber           String                 @unique @map("phone_number")
  openingHours          Json                   @map("opening_hours")
  carrier               String                 @default("vapi") // "vapi" | "telnyx" — rollback feature flag
  smsConfirmEnabled     Boolean                @default(true) @map("sms_confirm_enabled")
  theforkSavings        Decimal                @default(0) @map("thefork_savings") @db.Decimal(10, 2)
  googleCalendarId      String?                @map("google_calendar_id")
  googleRefreshToken    String?                @map("google_refresh_token")
  onboardingTasks       Json                   @default("{}") @map("onboarding_tasks")
  onboardingDone        Boolean                @default(false) @map("onboarding_done")
  onboardingCompletedAt DateTime?              @map("onboarding_completed_at")
  onboardingActivatedAt DateTime?              @map("onboarding_activated_at")
  onboardingLastSeenAt  DateTime?              @map("onboarding_last_seen_at")
  firstCallAt           DateTime?              @map("first_call_at")
  // Provisioning fields
  provisioningStatus     String                 @default("PENDING") @map("provisioning_status")
  telnyxPhoneNumberId    String?                @map("telnyx_phone_number_id")
  forwardingConfiguredAt DateTime?              @map("forwarding_configured_at")
  testCallValidatedAt    DateTime?              @map("test_call_validated_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at")
  calls                 Call[]
  reservations          Reservation[]
  customers             Customer[]
  messages              Message[]
  reactivationCampaigns ReactivationCampaign[]
  personality           AgentPersonality?
  callQuotas            CallQuota[]
  agenticHolds          AgenticHold[]
  floorPlans            FloorPlan[]
  giftCards             GiftCard[]
  giftCardPacks         GiftCardPack[]
  waitingListEntries    WaitingListEntry[]
  giftCardMinimumAmount Int?                      @map("gift_card_minimum_amount")
  giftCardCommissionRate Decimal  @default(0.05) @map("gift_card_commission_rate") @db.Decimal(5, 4)

  // Agentic reservations (P0)
  slug                 String?                     @unique @map("slug")
  canonicalUrl         String?                     @map("canonical_url")
  websiteUrl           String?                     @map("website_url")
  platformUrl          String?                     @map("platform_url")
  lat                  Decimal?                    @map("lat") @db.Decimal(9, 6)
  lng                  Decimal?                    @map("lng") @db.Decimal(9, 6)
  formattedAddress     String?                     @map("formatted_address")
  timezone             String                      @default("Europe/Paris") @map("timezone")
  phoneE164            String?                     @map("phone_e164")
  cuisineType          String[]                    @default([]) @map("cuisine_type")
  priceRange           Int?                        @map("price_range")
  ambiance             String[]                    @default([])
  noiseLevel           NoiseLevel?                 @map("noise_level")
  dietary              String[]                    @default([])
  attributeConfidence  Json                        @default("{}") @map("attribute_confidence")
  agenticOptIn         Boolean                     @default(false) @map("agentic_opt_in")
  openaiReserveEnabled Boolean                     @default(false) @map("openai_reserve_enabled")
  policyVersion        String                      @default("2026-06-20") @map("policy_version")
  exposureSettings     RestaurantExposureSettings?
  agentClients         AgentClient[]
  images               RestaurantImage[]
  onboardingEvents     OnboardingEvent[]
  copilotOccurrences   CopilotOccurrence[]

  // Sokar Connect (P0) — données publiques structurées, pas de flags de gating ici
  description   String?   @map("description")
  city          String?   @map("city")
  country       String    @default("FR") @map("country")
  postalCode    String?   @map("postal_code")
  coverImageUrl String?   @map("cover_image_url")
  publishedAt   DateTime? @map("published_at")

  // Google Places — rating importé (aggregateRating JSON-LD, Phase 3)
  // Sync périodique via worker google-places-sync. Respect CGU Google :
  // attribution obligatoire, pas de republication du texte des avis.
  googlePlaceId        String?   @map("google_place_id")
  googleRating         Float?    @map("google_rating")
  googleReviewCount    Int?      @map("google_review_count")
  googleRatingSyncedAt DateTime? @map("google_rating_synced_at")

  @@index([city, publishedAt], map: "restaurants_city_published_at_idx")
  @@map("restaurants")
}

model RestaurantImage {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  url          String
  alt          String?
  isCover      Boolean    @default(false) @map("is_cover")
  position     Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, isCover, position], map: "restaurant_images_restaurant_id_is_cover_position_idx")
  @@map("restaurant_images")
}

// ─── Floor plan (P1) ───────────────────────────────────────────────

model FloorPlan {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  name         String     @default("Salle principale")
  width        Int        @default(1400) @map("width")
  height       Int        @default(900) @map("height")
  isDefault    Boolean    @default(true) @map("is_default")
  isActive     Boolean    @default(true) @map("is_active")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sections     Section[]
  tables       Table[]
  walls        Wall[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([restaurantId, isDefault])
  @@index([restaurantId, isActive])
  @@map("floor_plans")
}

model Wall {
  id          String    @id @default(uuid())
  floorPlanId String    @map("floor_plan_id")
  x1          Int
  y1          Int
  x2          Int
  y2          Int
  type        String    @default("wall") @map("type")
  name        String?   @map("name")
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([floorPlanId])
  @@map("floor_plan_walls")
}

model Section {
  id          String    @id @default(uuid())
  floorPlanId String    @map("floor_plan_id")
  name        String
  position    Int       @default(0)
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  tables      Table[]
  waitingListEntries WaitingListEntry[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([floorPlanId, position])
  @@map("floor_plan_sections")
}

model Table {
  id           String        @id @default(uuid())
  floorPlanId  String        @map("floor_plan_id")
  sectionId    String?       @map("section_id")
  name         String
  capacity     Int
  minCapacity  Int           @default(1) @map("min_capacity")
  positionX    Int?          @map("position_x")
  positionY    Int?          @map("position_y")
  width        Int?          @map("width")
  height       Int?          @map("height")
  rotation     Int           @default(0) @map("rotation")
  shape        String        @default("rect")
  assignedServer String?     @map("assigned_server")
  isActive     Boolean       @default(true) @map("is_active")
  floorPlan    FloorPlan     @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  section      Section?      @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  reservations Reservation[]
  holds        AgenticHold[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([floorPlanId, isActive])
  @@index([floorPlanId, isActive, capacity])
  @@index([sectionId])
  @@map("floor_plan_tables")
}

model Call {
  id                          String              @id @default(uuid())
  restaurantId                String              @map("restaurant_id")
  callSid                     String              @unique @map("call_sid")
  durationSec                 Int?                @map("duration_sec")
  transcript                  String?
  intent                      CallIntent?
  outcome                     CallOutcome?
  sttProvider                 String?             @map("stt_provider")
  llmProvider                 String?             @map("llm_provider")
  ttsProvider                 String?             @map("tts_provider")
  carrier                     String?
  recordingStatus             CallRecordingStatus @default(NOT_REQUESTED) @map("recording_status")
  recordingProviderId         String?             @map("recording_provider_id")
  recordingStorageKey         String?             @map("recording_storage_key")
  recordingContentType        String?             @map("recording_content_type")
  recordingSizeBytes          Int?                @map("recording_size_bytes")
  recordingConsentAnnouncedAt DateTime?           @map("recording_consent_announced_at")
  recordingStartedAt          DateTime?           @map("recording_started_at")
  recordingEndedAt            DateTime?           @map("recording_ended_at")
  recordingExpiresAt          DateTime?           @map("recording_expires_at")
  recordingError              String?             @map("recording_error")
  createdAt                   DateTime            @default(now()) @map("created_at")
  updatedAt                   DateTime            @default(now()) @updatedAt @map("updated_at")
  restaurant                  Restaurant          @relation(fields: [restaurantId], references: [id])
  reservation                 Reservation?
  latencyTrace                LatencyTrace?
  messages                    Message[]

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([restaurantId, outcome, createdAt(sort: Desc)], map: "calls_restaurant_outcome_created_at_idx")
  @@index([recordingStatus, recordingExpiresAt], map: "calls_recording_status_expires_at_idx")
  @@map("calls")
}

model Reservation {
  id               String            @id @default(uuid())
  restaurantId     String            @map("restaurant_id")
  callId           String?           @unique @map("call_id")
  customerId       String?           @map("customer_id")
  reservedAt       DateTime          @map("reserved_at")
  partySize        Int               @map("party_size")
  customerName     String            @map("customer_name")
  customerPhone    String?           @map("customer_phone")
  customerEmail    String?           @map("customer_email")
  status           ReservationStatus @default(CONFIRMED)
  estimatedRevenue Decimal?          @map("estimated_revenue") @db.Decimal(10, 2)
  confirmedRevenue Decimal?          @map("confirmed_revenue") @db.Decimal(10, 2)
  googleEventId    String?           @map("google_event_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  restaurant       Restaurant        @relation(fields: [restaurantId], references: [id])
  call             Call?             @relation(fields: [callId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])

  // Agentic reservations (P0)
  channel                ReservationChannel @default(PHONE) @map("channel")
  state                  ReservationState   @default(CONFIRMED) @map("state")
  startsAt               DateTime?          @map("starts_at")
  endsAt                 DateTime?          @map("ends_at")
  specialRequests        String?            @map("special_requests")
  createdByClient        String?            @map("created_by_client")
  cancellationPolicySnap Json?              @map("cancellation_policy_snap")
  noShowPolicySnap       Json?              @map("no_show_policy_snap")
  consents               Json               @default("{}") @map("consents")
  privacyPolicyVersion   String             @default("2026-06-20") @map("privacy_policy_version")
  idempotencyScope       String?            @map("idempotency_scope")
  idempotencyKey         String?            @map("idempotency_key")
  idempotencyPayloadHash String?            @map("idempotency_payload_hash")
  // Partial unique index sur (idempotency_scope, idempotency_key) WHERE non nulls,
  // défini dans la migration 20260621000000_agentic_p0_columns. Prisma ne l'affiche
  // pas sans preview feature partialIndexes, d'ou ce commentaire.
  consumedHoldId         String?            @unique @map("consumed_hold_id")
  source                 String?            @map("source") // google|chatgpt|perplexity|bing|restaurant_website|instagram|qr_code|direct|unknown|web

  // SMS confirmation J-1
  confirmationStatus ConfirmationStatus @default(NOT_REQUIRED) @map("confirmation_status")
  confirmationSentAt DateTime?          @map("confirmation_sent_at")
  confirmedAt        DateTime?          @map("confirmed_at")

  auditLog ReservationAuditLog[]

  // Floor plan (P1)
  tableId String? @map("table_id")
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Waiting list (P3.2)
  promotedFromWaitingList WaitingListEntry?

  // Gift cards (P1)
  giftCardRedemptions GiftCardRedemption[]
  giftCardRedemptionSnap Json? @map("gift_card_redemption_snap")
  giftCardComplementAmount Decimal? @map("gift_card_complement_amount") @db.Decimal(10, 2)

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([restaurantId, status, createdAt(sort: Desc)])
  @@index([restaurantId, reservedAt])
  @@index([restaurantId, status, reservedAt], map: "reservations_restaurant_status_reserved_at_idx")
  @@index([customerId], map: "reservations_customer_id_idx")
  @@index([restaurantId, customerId], map: "reservations_restaurant_customer_id_idx")
  @@index([confirmationStatus, reservedAt], map: "reservations_confirmation_status_reserved_at_idx")
  @@index([restaurantId, tableId, startsAt])
  @@index([tableId, startsAt])
  @@map("reservations")
}

model AgentPersonality {
  id                  String      @id @default(uuid())
  restaurantId        String      @unique @map("restaurant_id")
  profileType         ProfileType @default(BISTROT_BRASSERIE) @map("profile_type")
  speakingRate        Decimal     @default(1.0) @map("speaking_rate") @db.Decimal(3, 2)
  pitchShift          Decimal     @default(1.0) @map("pitch_shift") @db.Decimal(3, 2)
  fillerStyle         FillerStyle @default(CASUAL) @map("filler_style")
  microphoneThreshold Int         @default(-42) @map("microphone_threshold")
  targetLatencyMs     Int         @default(140) @map("target_latency_ms")
  systemPromptExtra   String?     @map("system_prompt_extra")
  voiceIdCa           String?     @map("voice_id_ca")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  restaurant          Restaurant  @relation(fields: [restaurantId], references: [id])

  @@map("agent_personalities")
}

model CallQuota {
  restaurantId String     @map("restaurant_id")
  monthKey     String     @map("month_key")
  callCount    Int        @default(0) @map("call_count")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@id([restaurantId, monthKey])
  @@map("call_quotas")
}

model Customer {
  id               String        @id @default(uuid())
  restaurantId     String        @map("restaurant_id")
  phone            String
  name             String?
  visitCount       Int           @default(0) @map("visit_count")
  loyaltyScore     Decimal       @default(0) @map("loyalty_score") @db.Decimal(5, 2)
  isVip            Boolean       @default(false) @map("is_vip")
  notes            String?
  specialOccasion  String?       @map("special_occasion")
  lastSeenAt       DateTime?     @map("last_seen_at")
  lastCallAt       DateTime?     @map("last_call_at")
  partySizeTypical Decimal?      @map("party_size_typical") @db.Decimal(5, 2)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id])
  reservations     Reservation[]
  giftCards        GiftCard[]

  @@unique([restaurantId, phone])
  @@index([restaurantId, isVip])
  @@index([restaurantId, visitCount(sort: Desc)], map: "customers_restaurant_visit_count_idx")
  @@index([restaurantId, lastCallAt(sort: Desc)], map: "customers_restaurant_last_call_at_idx")
  @@map("customers")
}

model Message {
  id            String     @id @default(uuid())
  restaurantId  String     @map("restaurant_id")
  callId        String?    @map("call_id")
  customerName  String     @map("customer_name")
  customerPhone String?    @map("customer_phone")
  content       String
  status        String     @default("PENDING")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  call          Call?      @relation(fields: [callId], references: [id])

  @@index([restaurantId, status, createdAt(sort: Desc)], map: "messages_restaurant_status_created_at_idx")
  @@map("messages")
}

model ReactivationCampaign {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  status       String     @default("PENDING") // PENDING | SENT | DISMISSED
  customerIds  String[]   @map("customer_ids") // snapshot des VIPs dormants
  sentAt       DateTime?  @map("sent_at")
  sentCount    Int        @default(0) @map("sent_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, status, createdAt(sort: Desc)], map: "reactivation_campaigns_restaurant_status_created_at_idx")
  @@map("reactivation_campaigns")
}

model LatencyTrace {
  id             String   @id @default(uuid())
  callId         String   @unique @map("call_id")
  vadEndMs       Int?     @map("vad_end_ms")
  sttFinalMs     Int?     @map("stt_final_ms")
  llmFirstToken  Int?     @map("llm_first_token_ms")
  ttsFirstByte   Int?     @map("tts_first_byte_ms")
  audioPlayingMs Int?     @map("audio_playing_ms")
  totalE2eMs     Int?     @map("total_e2e_ms")
  createdAt      DateTime @default(now()) @map("created_at")
  call           Call     @relation(fields: [callId], references: [id])

  @@map("latency_traces")
}

enum Plan {
  ESSENTIAL
  STARTER
  PRO
  PREMIUM
}

enum CallIntent {
  RESERVATION
  HOURS
  MENU
  CANCEL
  OTHER
}

enum CallOutcome {
  RESERVED
  INFO
  NO_ACTION
  HANDOFF
  ERROR
}

enum CallRecordingStatus {
  NOT_REQUESTED
  PENDING
  AVAILABLE
  FAILED
  DELETED
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
  NO_SHOW
  SEATED
}

enum ConfirmationStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  CANCELLED
  NO_REPLY
}

enum ProfileType {
  BISTROT_BRASSERIE
  GASTRONOMIQUE
  SEMI_GASTRO
}

enum FillerStyle {
  CASUAL
  FORMAL
  WARM
}

// Agentic reservations enums (P0)
enum ReservationState {
  PENDING
  CONFIRMED
  SEATED
  HONORED
  CANCELLED
  NO_SHOW
  FAILED
  EXPIRED
}

enum ReservationChannel {
  PHONE
  WEB
  MCP
  OPENAI_RESERVE
  ADMIN
  API
}

enum HoldType {
  QUOTE
  HOLD
}

enum HoldStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  RELEASED
}

enum NoiseLevel {
  CALME
  MODERE
  ANIME
}

// Waiting list (P3.2)
enum WaitingListStatus {
  PENDING
  PROMOTED
  CANCELLED
  EXPIRED
}

// Agentic reservations models (P0)
model AgenticHold {
  id            String             @id @default(uuid())
  restaurantId  String             @map("restaurant_id")
  type          HoldType
  partySize     Int                @map("party_size")
  slotStart     DateTime           @map("slot_start")
  slotEnd       DateTime           @map("slot_end")
  channel       ReservationChannel
  quoteToken    String?            @unique @map("quote_token")
  holdToken     String?            @unique @map("hold_token")
  expiresAt     DateTime           @map("expires_at")
  consumedAt    DateTime?          @map("consumed_at")
  status        HoldStatus         @default(ACTIVE) @map("status")
  policyVersion String             @map("policy_version")
  reservationId String?            @map("reservation_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  restaurant    Restaurant         @relation(fields: [restaurantId], references: [id])

  // Floor plan (P1)
  tableId String? @map("table_id")
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([restaurantId, slotStart])
  @@index([expiresAt])
  @@index([status, expiresAt])
  @@index([tableId, slotStart])
  @@map("agentic_holds")
}

// Waiting list (P3.2)
model WaitingListEntry {
  id                      String            @id @default(uuid())
  restaurantId            String            @map("restaurant_id")
  partySize               Int               @map("party_size")
  customerFirstName       String            @map("customer_first_name")
  customerLastName        String?           @map("customer_last_name")
  customerPhone           String            @map("customer_phone")
  customerPhoneNormalized String            @map("customer_phone_normalized")
  customerEmail           String?           @map("customer_email")
  source                  String?           @map("source")
  slotStart               DateTime          @map("slot_start")
  slotEnd                 DateTime          @map("slot_end")
  preferredSectionId      String?           @map("preferred_section_id")
  status                  WaitingListStatus @default(PENDING) @map("status")
  position                Int               @default(0) @map("position")
  actionTokenHash         String            @unique @map("action_token_hash")
  promotedReservationId   String?           @unique @map("promoted_reservation_id")
  expiresAt               DateTime          @map("expires_at")
  promotedAt              DateTime?         @map("promoted_at")
  cancelledAt             DateTime?         @map("cancelled_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  restaurant              Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  preferredSection        Section?          @relation(fields: [preferredSectionId], references: [id], onDelete: SetNull)
  promotedReservation     Reservation?      @relation(fields: [promotedReservationId], references: [id], onDelete: SetNull)

  @@index([restaurantId, status, slotStart, createdAt])
  @@index([restaurantId, customerPhoneNormalized])
  @@index([expiresAt])
  @@map("waiting_list_entries")
}

model ReservationAuditLog {
  id            String       @id @default(uuid())
  reservationId String?      @map("reservation_id")
  holdId        String?      @map("hold_id")
  actor         String
  actorHash     String?      @map("actor_hash")
  event         String
  fromState     String?      @map("from_state")
  toState       String?      @map("to_state")
  correlationId String?      @map("correlation_id")
  metadata      Json         @default("{}")
  createdAt     DateTime     @default(now()) @map("created_at")
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  @@index([reservationId, createdAt])
  @@index([createdAt])
  @@index([actorHash])
  @@index([event, createdAt])
  @@map("reservation_audit_log")
}

// ─── Service Copilot telemetry (V1 quality loop, shadow mode) ─────────────

enum CopilotOccurrenceStatus {
  OBSERVED
  OPENED
  APPLIED
  REVERTED
  CONFLICTED
  EXPIRED
  IGNORED
}

enum CopilotTelemetryEventType {
  VIEWED
  OPENED
  APPLIED
  REVERTED
  CONFLICTED
  EXPIRED
  IGNORED
}

model CopilotOccurrence {
  id            String                  @id @default(uuid())
  restaurantId  String                  @map("restaurant_id")
  occurrenceKey String                  @map("occurrence_key")
  kind          String
  entityId      String?                 @map("entity_id")
  ruleVersion   String                  @map("rule_version")
  isShadow      Boolean                 @default(true) @map("is_shadow")
  status        CopilotOccurrenceStatus @default(OBSERVED)
  eligibleAt    DateTime                @default(now()) @map("eligible_at")
  expiresAt     DateTime?               @map("expires_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  restaurant Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  events     CopilotTelemetryEvent[]

  @@unique([restaurantId, occurrenceKey])
  @@index([restaurantId, kind, status])
  @@index([restaurantId, expiresAt])
  @@map("copilot_occurrences")
}

model CopilotTelemetryEvent {
  id             String                    @id @default(uuid())
  occurrenceId   String                    @map("occurrence_id")
  idempotencyKey String                    @unique @map("idempotency_key")
  event          CopilotTelemetryEventType
  reasonCode     String?                   @map("reason_code")
  actorHash      String?                   @map("actor_hash")
  metadata       Json                      @default("{}")
  clientTime     DateTime?                 @map("client_time")
  serverTime     DateTime                  @default(now()) @map("server_time")

  occurrence CopilotOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  @@index([occurrenceId, event])
  @@index([serverTime])
  @@map("copilot_telemetry_events")
}

model IdempotencyRecord {
  scope         String   @map("scope")
  key           String   @map("key")
  payloadHash   String   @map("payload_hash")
  reservationId String?  @map("reservation_id")
  status        String
  responseHash  String?  @map("response_hash")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")

  @@id([scope, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

model CustomerConsent {
  id                    String             @id @default(uuid())
  restaurantId          String             @map("restaurant_id")
  customerId            String?            @map("customer_id")
  reservationId         String?            @map("reservation_id")
  subjectHash           String             @map("subject_hash")
  channel               ReservationChannel
  context               String
  reservationProcessing Boolean            @map("reservation_processing")
  transactionalSms      Boolean            @map("transactional_sms")
  transactionalEmail    Boolean            @map("transactional_email")
  marketingOptIn        Boolean            @map("marketing_opt_in")
  privacyPolicyVersion  String             @map("privacy_policy_version")
  consentedAt           DateTime           @map("consented_at")
  consentIpHash         String?            @map("consent_ip_hash")
  createdAt             DateTime           @default(now()) @map("created_at")

  @@index([restaurantId, subjectHash])
  @@index([reservationId])
  @@index([createdAt])
  @@map("customer_consents")
}

// ─── Identity verification (RGPD Articles 12 §6, 17, 20) ────

model IdentityVerificationOtp {
  id          String    @id @default(uuid())
  subject     String
  intent      String
  otpHash     String    @map("otp_hash")
  channel     String
  destination String
  attempts    Int       @default(0)
  consumedAt  DateTime? @map("consumed_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([subject, intent])
  @@index([expiresAt])
  @@map("identity_verification_otps")
}

model SignedTokenUsage {
  jti     String   @id
  usedAt  DateTime @default(now()) @map("used_at")
  subject String?
  intent  String?

  @@index([usedAt])
  @@map("signed_token_usages")
}

model RestaurantExposureSettings {
  restaurantId            String     @id @map("restaurant_id")
  mcpEnabled              Boolean    @default(false) @map("mcp_enabled")
  openaiReserveEnabled    Boolean    @default(false) @map("openai_reserve_enabled")
  exposedCreneaux         Json       @default("[]") @map("exposed_creneaux")
  maxPartySize            Int        @default(12) @map("max_party_size")
  minLeadTimeMinutes      Int        @default(30) @map("min_lead_time_minutes")
  requireManualValidation Boolean    @default(false) @map("require_manual_validation")
  quoteTtlSeconds         Int        @default(300) @map("quote_ttl_seconds")
  holdTtlSeconds          Int        @default(420) @map("hold_ttl_seconds")
  noShowPolicy            String     @default("warning") @map("no_show_policy")
  notificationChannels    String[]   @default(["sms", "email"]) @map("notification_channels")
  capacitySpecials        Json       @default("{}") @map("capacity_specials")
  // Sokar Connect (P0) — source de vérité unique pour le gating
  connectPublished        Boolean    @default(false) @map("connect_published")
  connectAgentic          Boolean    @default(false) @map("connect_agentic")
  connectPublishedAt      DateTime?  @map("connect_published_at")
  connectDescription      String?    @map("connect_description")
  updatedAt               DateTime   @updatedAt @map("updated_at")
  restaurant              Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("restaurant_exposure_settings")
}

model AgentClient {
  id             String      @id @default(uuid())
  restaurantId   String?     @map("restaurant_id")
  name           String
  keyPrefix      String      @map("key_prefix")
  keyHash        String      @unique @map("key_hash")
  scopes         String[]    @default(["mcp:read", "mcp:reserve", "mcp:cancel"])
  allowedOrigins String[]    @default([]) @map("allowed_origins")
  revokedAt      DateTime?   @map("revoked_at")
  lastUsedAt     DateTime?   @map("last_used_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  restaurant     Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([keyPrefix])
  @@map("agent_clients")
}

/// Events d'analytics persistés pour le funnel onboarding.
/// Alimenté par le worker BullMQ `analytics` (queue partagée avec RGPD).
/// Permet de mesurer les drop-offs par étape sans outil externe.
model OnboardingEvent {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  userId       String?    @map("user_id")
  event        String
  task         String?
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([event, createdAt(sort: Desc)])
  @@map("onboarding_events")
}

// ─── Gift cards (P1) ───────────────────────────────────────────────

model GiftCard {
  id                String   @id @default(uuid())
  restaurantId      String   @map("restaurant_id")
  code              String   @unique @default(uuid())
  amount            Decimal  @db.Decimal(10, 2)
  remainingAmount   Decimal  @db.Decimal(10, 2) @map("remaining_amount")
  currency          String   @default("EUR")
  status            String   @default("ACTIVE") // ACTIVE, REDEEMED, EXPIRED, CANCELLED
  purchasedAt       DateTime @default(now()) @map("purchased_at")
  expiresAt         DateTime? @map("expires_at")
  validityMonths    Int      @default(12) @map("validity_months")

  // Montant libre ou pack expérience
  packId            String?   @map("pack_id")
  pack              GiftCardPack? @relation(fields: [packId], references: [id], onDelete: SetNull)

  // Option "réserver maintenant"
  preferredDate      DateTime? @map("preferred_date")
  preferredTime      String?   @map("preferred_time")
  preferredPartySize Int?      @map("preferred_party_size")

  senderName        String? @map("sender_name")
  senderEmail       String? @map("sender_email")
  senderPhone       String? @map("sender_phone")
  recipientName     String? @map("recipient_name")
  recipientEmail    String? @map("recipient_email")
  recipientPhone    String? @map("recipient_phone")
  message           String?
  occasion          String?
  customerId        String? @map("customer_id")
  createdBy         String   @default("CLIENT") @map("created_by") // CLIENT, DASHBOARD, VOICE
  purchaseReference String? @map("purchase_reference") // stripePaymentIntentId, manual, etc.

  // P2 — Stripe + personnalisation + commission
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  stripePaymentStatus   String?  @default("pending") @map("stripe_payment_status")
  templateId            String?  @map("template_id")
  customImageUrl        String?  @map("custom_image_url")
  sokarCommissionAmount Decimal  @map("sokar_commission_amount") @db.Decimal(10, 2)

  // P3 — Crowdfunding
  type              String    @default("SINGLE") @map("type") // SINGLE, CROWDFUNDED
  targetAmount      Decimal?  @map("target_amount") @db.Decimal(10, 2)
  crowdfundedUntil  DateTime? @map("crowdfunded_until") // deadline
  closedAt          DateTime? @map("closed_at") // date de clôture manuelle

  // P2 — Code court mnémonique (alias public lisible, le code UUID reste l'identifiant technique)
  shortCode         String?   @unique @map("short_code")

  restaurant    Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer      Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  redemptions   GiftCardRedemption[]
  contributions GiftCardContribution[]

  @@index([restaurantId, status])
  @@index([code])
  @@index([shortCode])
  @@map("gift_cards")
}

model GiftCardRedemption {
  id            String    @id @default(uuid())
  giftCardId    String    @map("gift_card_id")
  reservationId String?   @map("reservation_id")
  amount        Decimal   @db.Decimal(10, 2)
  redeemedAt    DateTime  @default(now()) @map("redeemed_at")

  giftCard    GiftCard     @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([giftCardId])
  @@map("gift_card_redemptions")
}

model GiftCardContribution {
  id                    String   @id @default(uuid())
  giftCardId            String   @map("gift_card_id")
  contributorName       String?  @map("contributor_name")
  contributorEmail      String?  @map("contributor_email")
  amount                Decimal  @db.Decimal(10, 2)
  contributedAt         DateTime @default(now()) @map("contributed_at")
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  isPublicName          Boolean  @default(true) @map("is_public_name")
  message               String?

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
  @@map("gift_card_contributions")
}

model GiftCardPack {
  id            String   @id @default(uuid())
  restaurantId  String   @map("restaurant_id")
  name          String
  description   String?
  amount        Decimal  @db.Decimal(10, 2)
  minPartySize  Int      @default(1) @map("min_party_size")
  maxPartySize  Int      @default(2) @map("max_party_size")
  isActive      Boolean  @default(true) @map("is_active")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  giftCards     GiftCard[]

  @@index([restaurantId, isActive])
  @@map("gift_card_packs")
}
