# Sokar — Variables d'environnement locales

DATABASE_URL="postgresql://sokar:password@localhost:5432/sokar_dev"
REDIS_URL="redis://localhost:6379"

# ─── App ───────────────────────────────────────────────────────────────────
PUBLIC_URL="http://localhost:4000"
OAUTH_ISSUER_URL="http://localhost:4000"
# SITE_URL : domaine canonique du site public Sokar Connect (sokar.tech).
# Utilisé par apps/connect (buildPublicRestaurantJsonLd dans @sokar/shared) pour les URLs @id/url du JSON-LD.
# En prod : https://sokar.tech
SITE_URL="http://localhost:4002"
PUBLIC_API_URL="http://localhost:4000"
DASHBOARD_URL="http://localhost:3000"
API_URL="http://127.0.0.1:4000"
NODE_ENV="development"
# Active les routes /api/test (simulation d'appel). En prod, doit être false (SEC-005).
ENABLE_TEST_ROUTES="true"
# Protection /metrics (SEC-006). Défaut : allowlist loopback. Auth basique prioritaire si user+password définis.
# METRICS_BASIC_AUTH_USER="prometheus"
# METRICS_BASIC_AUTH_PASSWORD="REPLACE"
# METRICS_ALLOWLIST_IPS="127.0.0.1, ::1"
# Active l'auth dev MCP (SEC-007). NE JAMAIS mettre true en production.
ENABLE_DEV_AUTH="true"
# AGENT_DEV_KEY="sk_sokar_agent_..."
# HMAC partagé pour le feed OpenAI Reserve (RES-007). Si défini, /v1/businesses
# exige un ?signature=... valide. Générer une clé ≥ 32 chars et la partager avec OpenAI.
# OPENAI_RESERVE_HMAC_KEY="REPLACE-WITH-32-CHAR-SECRET"
LOG_LEVEL="info"
TZ="Europe/Paris"
SENTRY_DSN=""

# ─── Auth ──────────────────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."

# ─── Telnyx / Voice ────────────────────────────────────────────────────────
TELNYX_API_KEY="KEY..."
# EU (Frankfurt) : TELNYX_API_URL="https://api.telnyx.eu" + TELNYX_API_BASE="api.telnyx.eu"
# US (défaut)    : laisser vide ou commenter
# TELNYX_API_URL="https://api.telnyx.eu"
# TELNYX_API_BASE="api.telnyx.eu"

# Enregistrement temporaire des appels de test (désactivé par défaut).
# Même activé, seuls les restaurants explicitement listés peuvent être enregistrés.
CALL_RECORDING_ENABLED="false"
CALL_RECORDING_TEST_RESTAURANT_IDS=""
CALL_RECORDINGS_BUCKET="sokar-call-recordings"
CALL_RECORDINGS_REGION="eu-west-3"
# Endpoint optionnel pour R2/MinIO ; laisser vide pour AWS S3.
# CALL_RECORDINGS_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# CALL_RECORDINGS_ACCESS_KEY_ID="..."
# CALL_RECORDINGS_SECRET_ACCESS_KEY="..."
CALL_RECORDINGS_RETENTION_DAYS="30"
CALL_RECORDINGS_MAX_BYTES="50000000"
TELNYX_PUBLIC_KEY="..."
TELNYX_APP_ID="..."
TELNYX_WEBHOOK_SECRET="..."
TELNYX_FROM_NUMBER="+33XXXXXXXXX"

# ─── WhatsApp Business via Telnyx BSP (optionnel) ──────────────────────────
# Telnyx est BSP WhatsApp officiel — embedded signup gère le Meta Business
# Manager de bout en bout. Même API key Telnyx que pour SMS/voice.
#
# Setup : Mission Control → Messaging → WhatsApp → Get Started (15 min)
# Puis créer le template "reservation_reminder" (UTILITY, fr) et attendre
# l'approbation Meta (24-48h).
#
# Si WHATSAPP_ENABLED=true, les rappels J-1 partent via WhatsApp (utility,
# ~€0.028/msg, 98% ouverture) au lieu de SMS (€0.06, 20%).
# Fallback SMS automatique si WhatsApp échoue.
# La réactivation VIP reste toujours sur SMS (marketing WhatsApp coûte 5x plus).
#
# WHATSAPP_ENABLED=

# ─── OpenRouter / LLM ──────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Provider primaire du pipeline vocal :
# - "cerebras" (défaut) : Gemma 4 31B, modèle 2026, plus intelligent
# - "openrouter"        : Llama 3.3 70B sur Groq, plus rapide (TTFT ~150ms)
# VOICE_LLM_PROVIDER="cerebras"

# Modèle LLM primaire (défaut : gemma-4-31b sur Cerebras)
# VOICE_LLM_MODEL="gemma-4-31b"

# Fallback (déclenché sur 429/5xx du primaire)
# CEREBRAS_API_KEY="csk-..."
# VOICE_LLM_FALLBACK_MODEL="meta-llama/llama-3.3-70b-instruct"

# ─── Deepgram STT ──────────────────────────────────────────────────────────
DEEPGRAM_API_KEY="..."
DEEPGRAM_MODEL="nova-3"
# EU (Frankfurt) : DEEPGRAM_API_HOST="api.eu.deepgram.com"
# US (défaut)    : laisser vide ou commenter
# DEEPGRAM_API_HOST="api.eu.deepgram.com"

# ─── Cartesia TTS ──────────────────────────────────────────────────────────
CARTESIA_API_KEY="..."
CARTESIA_VOICE_ID="f786b574-daa5-4673-aa0c-cbe3e8534c02"
# Canary : une continuité prosodique par réponse LLM via WebSocket Cartesia.
# Laisser false jusqu'aux appels contrôlés et mesures audio. Même à true,
# ConfigCat `voice_tts_context_v2` doit aussi cibler explicitement le restaurant.
VOICE_TTS_CONTEXT_V2_ENABLED="false"

# ─── Email ─────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_..."
EMAIL_FROM="noreply@sokar.fr"

# ─── Alertes ops (monitoring pilote) ────────────────────────────────────────
# Canaux de réception des alertes du worker system-health (toutes les 5 min :
# files BullMQ, jobs failed/dead-letter, webhooks Telnyx en erreur, appels sans
# transcription, réservations sans SMS). Tous optionnels ; sans aucun canal,
# les alertes ne partent que dans les logs + Sentry.
#   Destinataires email des alertes (séparés par des virgules) :
# ALERT_EMAIL_TO="ops@sokar.tech"
#   Webhook Slack/Discord (payload { "text": "..." }) :
# ALERT_WEBHOOK_URL="https://hooks.slack.com/services/..."
#   Numéro E.164 recevant un SMS pour les alertes CRITIQUES uniquement :
# ALERT_SMS_TO="+33612345678"
# Note : le watchdog VPS (scripts/ops/sokar-watchdog.sh) a sa propre config
# dans /etc/sokar/watchdog.env (ALERT_WEBHOOK / ALERT_CMD / HEALTHCHECKS_PING_URL).

# ─── Stripe (cartes cadeaux) ───────────────────────────────────────────────
STRIPE_SECRET_KEY="..."
STRIPE_PUBLISHABLE_KEY="..."
# Secret de signature du webhook : Stripe Dashboard → Développeurs → Webhooks → endpoint secret.
STRIPE_WEBHOOK_SECRET="..."

# ─── Google Calendar ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
GOOGLE_REDIRECT_URI="http://localhost:4000/integrations/google-calendar/callback"

# ─── Google Places (aggregateRating Connect, Phase 3) ──────────────────────
# API key pour Google Places Details (rating + reviewCount).
# Sync périodique via worker google-places-sync (1x/jour par resto avec Place ID).
# Respect CGU Google : attribution obligatoire, pas de republication des avis.
# GOOGLE_PLACES_API_KEY=""

# ─── Captcha Cloudflare Turnstile (SEC-009) ───────────────────────────────
# Si défini, /api/rgpd/request-verification exige un token Turnstile côté client.
# TURNSTILE_SECRET_KEY=""

# ─── Feature flags ─────────────────────────────────────────────────────────
TTS_CACHE_ENABLED="true"
VIP_PUSH_ENABLED="false"
SPECULATIVE_LLM_ENABLED="false"
# Optionnel : limiter la pré-réflexion LLM à des restaurants canaris.
# Vide = tous les restaurants lorsque le flag global est activé.
SPECULATIVE_LLM_RESTAURANT_IDS=""

# ─── AWS / LocalStack ──────────────────────────────────────────────────────
AWS_REGION="eu-west-1"
# USE_LOCALSTACK="true"
# LOCALSTACK_AUTH_TOKEN="ls-..."

# ─── ConfigCat Feature Flags ─────────────────────────────────────────────
# CONFIGCAT_SDK_KEY="..."

# ─── Sentry (error tracking) ───────────────────────────────────────────
# API + Dashboard server/edge
# SENTRY_DSN="https://..."
# SENTRY_RELEASE="1.0.0"
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# SENTRY_SAMPLE_RATE="1.0"

# Dashboard client only
# NEXT_PUBLIC_SENTRY_DSN="https://..."
# NEXT_PUBLIC_SENTRY_RELEASE="1.0.0"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
# NEXT_PUBLIC_SENTRY_SAMPLE_RATE="1.0"
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="0"
