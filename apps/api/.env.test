DATABASE_URL="postgresql://callyx:password@localhost:5432/sokar_test"
REDIS_URL="redis://localhost:6379"
TELNYX_API_KEY="test-telnyx-key"
TELNYX_PUBLIC_KEY="test-public-key"
TELNYX_FROM_NUMBER="+33100000000"
TELNYX_WEBHOOK_SECRET="test-telnyx-secret"
DEEPGRAM_API_KEY="test-deepgram-key"
DEEPGRAM_MODEL="nova-3"
TZ="Europe/Paris"
NODE_ENV="test"
# Active les routes /api/test pour les tests. En prod, doit être false (SEC-005).
ENABLE_TEST_ROUTES="true"
# /metrics accessible depuis loopback en tests (SEC-006).
METRICS_ALLOWLIST_IPS="127.0.0.1, ::1"
# Auth dev MCP désactivée par défaut en tests (SEC-007). Les tests la mutent explicitement.
ENABLE_DEV_AUTH="false"
# HMAC OpenAI Reserve (RES-007). Les tests le mutent explicitement.
# OPENAI_RESERVE_HMAC_KEY="test-openai-reserve-hmac-key-32-chars"
TTS_CACHE_ENABLED="false"
VIP_PUSH_ENABLED="false"
