# Sokar — Variables d'environnement STAGING
#
# Copie ce fichier en .env sur le VPS staging (/opt/sokar-staging/apps/api/.env).
# JAMAIS de clés de prod. Voice désactivée. Stripe en mode test.
#
# DB : sokar_staging (séparée de sokar_dev / sokar_prod).
# Redis : db=2 (prod utilise db=0).
#
# Prisma/PostgreSQL timeouts — recommandé : ajouter ?statement_timeout=10000
# à DATABASE_URL pour qu'PostgreSQL tue les requêtes qui dépassent 10s au
# niveau serveur (garde-fou en plus des transactionOptions Prisma).
# Ex: DATABASE_URL="postgresql://user:pass@host:5432/db?statement_timeout=10000&connect_timeout=10"

DATABASE_URL="postgresql://sokar:CHANGE_ME_PASSWORD@localhost:5432/sokar_staging"
REDIS_URL="redis://localhost:6379/2"

# ─── App ───────────────────────────────────────────────────────────────────
PUBLIC_URL="https://api-staging.sokar.tech"
OAUTH_ISSUER_URL="https://api-staging.sokar.tech"
SITE_URL="https://staging.sokar.tech"
PUBLIC_API_URL="https://api-staging.sokar.tech"
DASHBOARD_URL="https://staging.sokar.tech"
API_URL="http://127.0.0.1:4100"
NODE_ENV="production"
# Routes /api/test desactivées explicitement en staging/production (SEC-005).
ENABLE_TEST_ROUTES="false"
# Protection /metrics (SEC-006). Allowlist loopback si Prometheus scrape via Nginx local.
# Pour auth basique, définir METRICS_BASIC_AUTH_USER + METRICS_BASIC_AUTH_PASSWORD.
METRICS_ALLOWLIST_IPS="127.0.0.1, ::1"
# Auth dev MCP strictement désactivée en staging/production (SEC-007).
ENABLE_DEV_AUTH="false"
# HMAC partagé pour le feed OpenAI Reserve (RES-007). Décommenter + renseigner
# pour exiger un ?signature=... valide sur /v1/businesses.
# OPENAI_RESERVE_HMAC_KEY=""
LOG_LEVEL="debug"
TZ="Europe/Paris"
SENTRY_DSN=""

# CORS — allowlist explicite des origins navigateur (comma-separated).
# En production, CORS_ORIGINS est OBLIGATOIRE (fail-fast au démarrage si absent).
CORS_ORIGINS="https://staging.sokar.tech,https://www.staging.sokar.tech"

# Reverse proxy IPs (Nginx, Cloudflare). Comma-separated.
# Local Nginx on the same VPS uses 127.0.0.1. Add the VPS public IP if needed.
TRUSTED_PROXY_IPS="127.0.0.1, ::1, 159.223.175.135"

# ─── Auth (Clerk STAGING — pk_test / sk_test) ──────────────────────────────
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# ─── Voice : DÉSACTIVÉE en staging ─────────────────────────────────────────
# VOICE_DISABLED=true indique à env.ts de ne pas valider les clés voice.
# L'API n'initialise pas le client Telnyx sans TELNYX_API_KEY. Les webhooks
# entrants échouent la vérification de signature (403). Deepgram/Cartesia
# ne sont pas appelés non plus. NE PAS renseigner de clés prod ici.
VOICE_DISABLED="true"
TELNYX_API_KEY=""
TELNYX_PUBLIC_KEY=""
TELNYX_APP_ID=""
TELNYX_WEBHOOK_SECRET=""
TELNYX_FROM_NUMBER=""

# ─── OpenRouter / LLM (optionnel en staging) ───────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ─── Deepgram STT (désactivé en staging) ───────────────────────────────────
DEEPGRAM_API_KEY=""
DEEPGRAM_MODEL="nova-3"

# ─── Cartesia TTS (désactivé en staging) ───────────────────────────────────
CARTESIA_API_KEY=""
CARTESIA_VOICE_ID="f786b574-daa5-4673-aa0c-cbe3e8534c02"

# ─── Email (désactivé — pas de SMTP en staging) ────────────────────────────
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@staging.sokar.tech"

# ─── Stripe (mode TEST) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="..."

# ─── Google Calendar (désactivé en staging) ────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# ─── Feature flags ─────────────────────────────────────────────────────────
TTS_CACHE_ENABLED="true"
VIP_PUSH_ENABLED="false"
SPECULATIVE_LLM_ENABLED="false"
