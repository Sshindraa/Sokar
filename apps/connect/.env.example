# apps/connect/.env.example
# Copie ce fichier en .env (jamais commité) avec les vraies valeurs.
# En prod : /opt/sokar/apps/connect/.env (sourcé par bin/run-connect.sh).
#
# Site public — utilisé pour canonical, OpenGraph, JSON-LD
SITE_URL=https://sokar.tech

# Dashboard (apps/dashboard) — utilisé pour autoriser l'iframe preview
# (?preview=1) dans le middleware Sokar Connect.
# En local : http://localhost:3000
# En prod : https://sokar.tech (même domaine, 'self' suffit)
DASHBOARD_URL=http://localhost:3000

# API Fastify (apps/api) — utilisée pour les fetches SSR (availability, hold, confirm)
# En local : http://localhost:3001
# En prod : http://127.0.0.1:4000 (interne, pas public)
API_URL=http://localhost:3001

# Port d'écoute du serveur Next standalone
PORT=4002
HOSTNAME=0.0.0.0

# API Fastify (apps/api) — utilisée pour les fetches SSR ET client (BookingWidget)
# NEXT_PUBLIC_API_URL est exposée au bundle client (préfixe NEXT_PUBLIC_)
# En local : http://localhost:3001
# En prod : https://sokar.tech (le client passe par Nginx qui route /api/* vers l'API)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Telemetry Next.js — désactivée par défaut
NEXT_TELEMETRY_DISABLED=1

# ─── Sentry (optionnel, error tracking SSR) ─────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://...
# SENTRY_DSN=https://...
# SENTRY_RELEASE=1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_SAMPLE_RATE=1.0
