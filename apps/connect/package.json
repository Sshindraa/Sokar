{
  "name": "@sokar/connect",
  "version": "0.1.0",
  "private": true,
  "description": "Sokar Connect — Agent-Ready Pages (Sokar public pages for AI/SEO indexability)",
  "scripts": {
    "dev": "next dev -p 4002",
    "build": "bash ../../scripts/build/guard-next-build.sh 4002 connect && next build",
    "start": "next start -p 4002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "copy-static": "bash scripts/copy-static.sh",
    "clean": "rm -rf .turbo .next"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.63.0",
    "@sokar/shared": "workspace:*",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.16.0",
    "next": "^15.5.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}
