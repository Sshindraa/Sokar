# apps/connect/.env.staging.example
# Copie ce fichier en .env sur le VPS staging (/opt/sokar-staging/apps/connect/.env).

# Site public staging — utilisé pour canonical, OpenGraph, JSON-LD
SITE_URL=https://staging.sokar.tech

# Dashboard staging — autorisation iframe preview
DASHBOARD_URL=https://staging.sokar.tech

# API Fastify staging — fetches SSR (interne, port 4100)
API_URL=http://127.0.0.1:4100

# Port d'écoute du serveur Next standalone (staging)
PORT=4102
HOSTNAME=0.0.0.0

# API Fastify staging — exposée au client (préfixe NEXT_PUBLIC_)
# Le client passe par Nginx qui route /api/* vers l'API staging.
NEXT_PUBLIC_API_URL=https://staging.sokar.tech

NEXT_TELEMETRY_DISABLED=1

# ─── Stripe (mode TEST) ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
