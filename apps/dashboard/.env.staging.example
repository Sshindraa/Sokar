# apps/dashboard/.env.staging.example
# Copie ce fichier en .env sur le VPS staging (/opt/sokar-staging/apps/dashboard/.env).
# Clés Clerk STAGING (pk_test / sk_test). JAMAIS de clés prod.

# ─── Auth (Clerk STAGING) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/restaurant

# ─── Stripe (mode TEST) ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── API ───────────────────────────────────────────────────────────────────
# Le dashboard proxy les appels API via /api/proxy/* (Next route handlers).
# En staging : API staging interne sur port 4100.
API_URL=http://127.0.0.1:4100

# ─── Email (désactivé en staging) ──────────────────────────────────────────
EMAIL_FROM=noreply@staging.sokar.tech
