# apps/dashboard/.env.example
# Copie ce fichier en .env (jamais commité) avec les vraies valeurs.
# En prod, .env est sourcé par bin/run-dashboard.sh au démarrage PM2.
#
# Les vars NEXT_PUBLIC_* sont baked au build time Next.js — elles doivent
# être présentes dans l'environnement lors de `next build`, pas seulement
# au runtime. Le deploy-vps.sh build après avoir vérifié .env.

# ─── Auth (Clerk) ──────────────────────────────────────────────────────────
# Obligatoire en prod. Sans NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY, le middleware
# ne peut pas protéger /dashboard et /onboarding.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_***
CLERK_SECRET_KEY=sk_test_***
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/restaurant

# ─── Stripe (cartes cadeaux) ───────────────────────────────────────────────
# Exposée au bundle client Next.js — doit être présente au build time.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=...

# ─── API ───────────────────────────────────────────────────────────────────
# Le dashboard proxy les appels API via /api/proxy/* (Next route handlers).
# API_URL est utilisée côté serveur pour forward vers Fastify.
# En prod : http://127.0.0.1:4000 (interne)
# En dev : http://localhost:4000
API_URL=http://localhost:4000

# ─── Email (optionnel) ────────────────────────────────────────────────────
# Brevo pour les newsletters, Resend pour les transactionnels.
# BREVO_API_KEY=***
# BREVO_LIST_ID=***
# RESEND_API_KEY=***
EMAIL_FROM=noreply@sokar.fr

# ─── Sentry (optionnel) ───────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=***
# SENTRY_DSN=***
