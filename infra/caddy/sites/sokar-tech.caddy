# Alternative Caddy configuration.
#
# Production currently uses infra/nginx/sokar.conf as the canonical proxy.
# Keep this file behaviorally equivalent so a deliberate Caddy migration does
# not break Next route handlers or api.sokar.tech.
#
# Reverse-proxy les chemins publics vers les services internes.
# Le dashboard (sokar-dashboard) garde les routes auth et marketing.
# Canal A (sokar-canal-a) sert les pages publiques agent-ready.
# L'API (sokar-api) sert les endpoints /api/*.
#
# Note Caddy :
#   - `encode zstd gzip` pour compresser HTML/CSS/JS
#   - `header` pour override des headers Cloudflare
#   - `reverse_proxy` avec health check et timeouts

sokar.tech, www.sokar.tech {
    # ─── Canal A : pages publiques agent-ready ────────────────
    # /r/{slug}            → page restaurant
    # /r/{slug}/book       → page booking
    # /restaurants/{city}  → pages locales (P2)
    # /sitemap.xml         → sitemap dynamique Canal A
    # /robots.txt          → robots dynamique
    @canalA path /r/* /restaurants/* /sitemap.xml /robots.txt
    reverse_proxy @canalA 127.0.0.1:4002 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        transport http {
            dial_timeout 5s
            response_header_timeout 30s
        }
    }

    # ─── Canal A static assets ────────────────────────────────
    handle /canal-a-assets/* {
        reverse_proxy 127.0.0.1:4002 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            transport http {
                dial_timeout 5s
                response_header_timeout 30s
            }
        }
    }

    # ─── Next.js API route handlers ───────────────────────────
    # Kept separate from the Fastify matcher below.
    @nextApi path /api/proxy/* /api/auth/sync
    reverse_proxy @nextApi 127.0.0.1:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # ─── API Fastify ──────────────────────────────────────────
    @api {
        path /api/*
        not path /api/proxy/* /api/auth/sync
    }
    reverse_proxy @api 127.0.0.1:4000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        transport http {
            dial_timeout 5s
            response_header_timeout 30s
        }
    }

    # ─── Widget de réservation embarquable (iframe tiers) ─────
    # /widget/{restaurantId} → page Next.js du dashboard, mais avec
    # headers de sécurité assouplis pour autoriser l'embed iframe.
    # L'API proxy est servie par la route @nextApi au-dessus (same-origin
    # depuis l'iframe puisque tout vient de sokar.tech).
    @widget path /widget/*
    reverse_proxy @widget 127.0.0.1:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        transport http {
            dial_timeout 5s
            response_header_timeout 30s
        }
    }
    # Override des headers de sécurité globaux pour le widget.
    # - Retire X-Frame-Options (sinon DENY/SAMEORIGIN bloquerait l'embed)
    # - CSP frame-ancestors * : autorise n'importe quel site tiers à embed
    #   (standard industrie : Calendly, OpenTable, Resy font pareil).
    #   À durcir en allowlist par restaurant si besoin.
    # - Cache-Control : no-store pour éviter de servir des pages widget
    #   cachées d'un autre restaurant.
    header @widget {
        # Retire le X-Frame-Options hérité du bloc global
        -X-Frame-Options
        # CSP minimale orientée embed iframe (le widget n'utilise pas
        # d'eval / object, juste son propre bundle Next).
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self' data:; connect-src 'self'; frame-ancestors *; base-uri 'self'; form-action 'self'"
        # Pas de cache : le widget est dynamique par restaurant
        Cache-Control "no-store, no-cache, must-revalidate"
        # Désactive l'HSTS sur cette route (inutile dans un iframe, et on
        # ne veut pas qu'un 503 sur /widget casse l'HSTS du host tiers)
        Strict-Transport-Security ""
    }

    # ─── Dashboard Sokar (Next.js port 3000) ──────────────────
    # Tout le reste (landing marketing, /pricing, /login, /dashboard/*, /mcp, etc.)
    reverse_proxy 127.0.0.1:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        transport http {
            dial_timeout 5s
            response_header_timeout 30s
        }
    }

    # Compression
    encode zstd gzip

    # Headers de sécurité additionnels (le middleware Next les porte déjà,
    # mais double-écrire est OK — le dernier gagne côté Cloudflare).
    header {
        # HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Pas de MIME sniff
        X-Content-Type-Options "nosniff"
        # Pas de referrer vers des sites tiers
        Referrer-Policy "strict-origin-when-cross-origin"
        # Permissions Policy : pas de caméra/micro/géoloc
        Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        # Cache par défaut : pas de cache pour les réponses dynamiques
        Cache-Control "public, max-age=0, must-revalidate"
        # Masquer Caddy
        -Server
    }

    # Logs
    log {
        output file /var/log/caddy/sokar-tech.log {
            roll_size 100MiB
            roll_keep 5
        }
    }
}

# Public API, MCP, OAuth, OpenAI Reserve and Telnyx WebSockets.
api.sokar.tech {
    reverse_proxy 127.0.0.1:4000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        transport http {
            dial_timeout 5s
            response_header_timeout 86400s
        }
    }

    encode zstd gzip
    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}
