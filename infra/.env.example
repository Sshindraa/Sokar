# ── Sokar infra env vars ──────────────────────────────────────────────────
# Copy to .env and fill in real values before `docker compose up`.
# docker-compose.yml reads POSTGRES_PASSWORD from this file at startup;
# LOCALSTACK_AUTH_TOKEN is optional (free tier works without).

# ── PostgreSQL ──
# Used by services.postgres.environment.POSTGRES_PASSWORD.
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=change-me-locally

# ── LocalStack (AWS emulation in dev) ──
# Optional. Free tier works without; the auth token unlocks Pro features.
# Get one at https://app.localstack.cloud
LOCALSTACK_AUTH_TOKEN=

# Set to 1 to enable LocalStack verbose logging (noisy — debug only).
LOCALSTACK_DEBUG=0
